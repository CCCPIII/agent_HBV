# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./investment_agent.db

# ── AI Model (choose one provider, or leave all empty for rule-based fallback) ─
ACTIVE_LLM_PROVIDER=openai        # openai | deepseek | kimi | zhipu | gemini | claude

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k

ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Telegram notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alert settings ────────────────────────────────────────────────────────────
PRICE_ALERT_DEFAULT_THRESHOLD=5.0
